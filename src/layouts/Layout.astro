---
interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en" class="dark">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Chat with your PDF using AI" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		<script is:inline>
			(function() {
				const saved = localStorage.getItem('theme');
				const mode = saved || 'system';
				const root = document.documentElement;
				if (mode === 'system') {
					const prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches;
					root.classList.toggle('dark', prefersDark);
					root.classList.toggle('light', !prefersDark);
				} else {
					root.classList.toggle('dark', mode === 'dark');
					root.classList.toggle('light', mode === 'light');
				}
			})();
		</script>
	</head>
	<body class="app">
		<slot />
	</body>
</html>

<style is:global>
	/* ===========================
	   THEME CSS VARIABLES (BEM root)
	   =========================== */
	:root {
		--app__font: 'Inter', system-ui, -apple-system, sans-serif;
		--app__accent: 139, 92, 246;
		--app__radius-sm: 0.5rem;
		--app__radius-md: 0.75rem;
		--app__radius-lg: 1rem;
		--app__radius-xl: 1.25rem;
		--app__transition: 0.3s ease;
	}

	/* DARK THEME */
	html.dark {
		--app__bg: #0a0a0f;
		--app__bg-secondary: #111118;
		--app__bg-card: rgba(15, 15, 25, 0.6);
		--app__bg-input: rgba(15, 15, 25, 0.8);
		--app__bg-hover: rgba(139, 92, 246, 0.06);
		--app__text-primary: #e2e8f0;
		--app__text-secondary: #94a3b8;
		--app__text-muted: #64748b;
		--app__border: rgba(139, 92, 246, 0.15);
		--app__border-hover: rgba(139, 92, 246, 0.4);
		--app__border-focus: rgba(139, 92, 246, 0.6);
		--app__shadow-card: 0 8px 32px rgba(0, 0, 0, 0.3);
		--app__shadow-inset: inset 0 1px 0 rgba(255, 255, 255, 0.05);
		--app__gradient-bg-start: #0a0a1a;
		--app__gradient-bg-mid: #0f0b1e;
		--app__gradient-bg-end: #0a0a1a;
		--app__orb-opacity: 0.10;
		--app__grid-color: rgba(139, 92, 246, 0.03);
		--app__accent-soft: rgba(139, 92, 246, 0.10);
		--app__accent-muted: rgba(139, 92, 246, 0.03);
		--app__input-placeholder: rgba(148, 163, 184, 0.5);
		--app__scrollbar-thumb: rgba(139, 92, 246, 0.3);
		--app__scrollbar-thumb-hover: rgba(139, 92, 246, 0.5);
		--app__badge-bg: rgba(0, 0, 0, 0.6);
		color-scheme: dark;
	}

	/* LIGHT THEME */
	html.light {
		--app__bg: #f8f9fc;
		--app__bg-secondary: #ffffff;
		--app__bg-card: rgba(255, 255, 255, 0.85);
		--app__bg-input: rgba(255, 255, 255, 0.9);
		--app__bg-hover: rgba(139, 92, 246, 0.04);
		--app__text-primary: #1e293b;
		--app__text-secondary: #475569;
		--app__text-muted: #94a3b8;
		--app__border: rgba(139, 92, 246, 0.15);
		--app__border-hover: rgba(139, 92, 246, 0.35);
		--app__border-focus: rgba(139, 92, 246, 0.5);
		--app__shadow-card: 0 8px 32px rgba(139, 92, 246, 0.08), 0 1px 3px rgba(0,0,0,0.06);
		--app__shadow-inset: inset 0 1px 0 rgba(255, 255, 255, 0.8);
		--app__gradient-bg-start: #f0eef6;
		--app__gradient-bg-mid: #ece8f8;
		--app__gradient-bg-end: #f0eef6;
		--app__orb-opacity: 0.08;
		--app__grid-color: rgba(139, 92, 246, 0.04);
		--app__accent-soft: rgba(139, 92, 246, 0.08);
		--app__accent-muted: rgba(139, 92, 246, 0.03);
		--app__input-placeholder: rgba(100, 116, 139, 0.6);
		--app__scrollbar-thumb: rgba(139, 92, 246, 0.2);
		--app__scrollbar-thumb-hover: rgba(139, 92, 246, 0.4);
		--app__badge-bg: rgba(255, 255, 255, 0.7);
		color-scheme: light;
	}

	/* ===========================
	   BASE STYLES
	   =========================== */
	html {
		font-family: var(--app__font);
		background: var(--app__bg);
		color: var(--app__text-primary);
		-webkit-font-smoothing: antialiased;
		-moz-osx-font-smoothing: grayscale;
		transition: background var(--app__transition), color var(--app__transition);
	}

	body.app {
		margin: 0;
		min-height: 100vh;
		display: flex;
		flex-direction: column;
	}

	/* Scrollbar */
	::-webkit-scrollbar { width: 6px; }
	::-webkit-scrollbar-track { background: transparent; }
	::-webkit-scrollbar-thumb {
		background: var(--app__scrollbar-thumb);
		border-radius: 3px;
	}
	::-webkit-scrollbar-thumb:hover {
		background: var(--app__scrollbar-thumb-hover);
	}

	/* ===========================
	   KEYFRAMES
	   =========================== */
	@keyframes float {
		0%, 100% { transform: translateY(0px); }
		50% { transform: translateY(-10px); }
	}
	@keyframes pulse-glow {
		0%, 100% { opacity: 0.4; }
		50% { opacity: 0.8; }
	}
	@keyframes fade-in-up {
		from { opacity: 0; transform: translateY(20px); }
		to { opacity: 1; transform: translateY(0); }
	}
	@keyframes shimmer {
		0% { background-position: -200% 0; }
		100% { background-position: 200% 0; }
	}
	@keyframes spin {
		to { transform: rotate(360deg); }
	}

	/* ===========================
	   BEM: page-bg (background layer)
	   =========================== */
	.page-bg {
		position: fixed;
		inset: 0;
		z-index: -1;
		overflow: hidden;
	}
	.page-bg__gradient {
		position: absolute;
		inset: 0;
		background: linear-gradient(135deg,
			var(--app__gradient-bg-start),
			var(--app__gradient-bg-mid),
			var(--app__gradient-bg-end));
		transition: background var(--app__transition);
	}
	.page-bg__orb {
		position: absolute;
		border-radius: 50%;
		filter: blur(120px);
		transition: opacity var(--app__transition);
	}
	.page-bg__orb--top {
		top: -20%;
		left: -10%;
		width: 600px;
		height: 600px;
		background: rgba(var(--app__accent), var(--app__orb-opacity));
		animation: float 6s ease-in-out infinite;
	}
	.page-bg__orb--bottom {
		bottom: -10%;
		right: -10%;
		width: 500px;
		height: 500px;
		background: rgba(99, 102, 241, var(--app__orb-opacity));
		animation: float 8s ease-in-out infinite reverse;
	}
	.page-bg__orb--center {
		top: 40%;
		right: 20%;
		width: 300px;
		height: 300px;
		background: rgba(167, 139, 250, calc(var(--app__orb-opacity) * 0.5));
		filter: blur(80px);
		animation: float 10s ease-in-out infinite;
	}
	.page-bg__grid {
		position: absolute;
		inset: 0;
		background:
			linear-gradient(var(--app__grid-color) 1px, transparent 1px),
			linear-gradient(90deg, var(--app__grid-color) 1px, transparent 1px);
		background-size: 64px 64px;
	}

	/* ===========================
	   BEM: page (main layout)
	   =========================== */
	.page {
		display: flex;
		flex-direction: column;
		align-items: center;
		justify-content: center;
		min-height: 100vh;
		width: 100%;
		padding: 3rem 1rem;
		box-sizing: border-box;
	}

	/* ===========================
	   BEM: header
	   =========================== */
	.header {
		display: flex;
		flex-direction: column;
		align-items: center;
		text-align: center;
		margin-bottom: 2.5rem;
		animation: fade-in-up 0.6s ease-out forwards;
	}
	.header__icon {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 4rem;
		height: 4rem;
		border-radius: var(--app__radius-lg);
		background: linear-gradient(135deg, rgba(var(--app__accent), 0.2), rgba(99, 102, 241, 0.2));
		border: 1px solid rgba(var(--app__accent), 0.2);
		margin-bottom: 1.5rem;
	}
	.header__icon svg {
		width: 2rem;
		height: 2rem;
		color: rgb(var(--app__accent));
	}
	.header__title {
		font-size: clamp(2.25rem, 5vw, 3.5rem);
		font-weight: 700;
		letter-spacing: -0.025em;
		margin: 0 0 0.75rem;
		background: linear-gradient(135deg, #a78bfa, #818cf8, #6366f1);
		-webkit-background-clip: text;
		-webkit-text-fill-color: transparent;
		background-clip: text;
	}
	.header__subtitle {
		color: var(--app__text-secondary);
		font-size: 1.05rem;
		max-width: 28rem;
		margin: 0;
		line-height: 1.6;
	}

	/* ===========================
	   BEM: card (glass container)
	   =========================== */
	.card {
		width: 100%;
		max-width: 42rem;
		padding: 2rem 2.5rem;
		background: var(--app__bg-card);
		backdrop-filter: blur(20px);
		-webkit-backdrop-filter: blur(20px);
		border: 1px solid var(--app__border);
		border-radius: var(--app__radius-xl);
		box-shadow: var(--app__shadow-card), var(--app__shadow-inset);
		animation: fade-in-up 0.6s ease-out forwards;
		animation-delay: 0.15s;
		opacity: 0;
		transition: background var(--app__transition), border-color var(--app__transition), box-shadow var(--app__transition);
	}

	/* ===========================
	   BEM: theme-toggle
	   =========================== */
	.theme-toggle {
		position: fixed;
		top: 1.25rem;
		right: 1.25rem;
		z-index: 50;
		display: flex;
		align-items: center;
		gap: 0.25rem;
		padding: 0.3rem;
		border-radius: 9999px;
		background: var(--app__bg-card);
		backdrop-filter: blur(12px);
		-webkit-backdrop-filter: blur(12px);
		border: 1px solid var(--app__border);
		box-shadow: 0 2px 8px rgba(0,0,0,0.1);
		animation: fade-in-up 0.6s ease-out forwards;
		animation-delay: 0.3s;
		opacity: 0;
		transition: background var(--app__transition), border-color var(--app__transition);
	}
	.theme-toggle__btn {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 2rem;
		height: 2rem;
		border-radius: 50%;
		border: none;
		background: transparent;
		color: var(--app__text-muted);
		cursor: pointer;
		transition: all var(--app__transition);
	}
	.theme-toggle__btn:hover {
		color: var(--app__text-primary);
		background: var(--app__accent-soft);
	}
	.theme-toggle__btn--active {
		background: linear-gradient(135deg, rgba(var(--app__accent), 0.25), rgba(99, 102, 241, 0.2));
		color: rgb(var(--app__accent));
		box-shadow: 0 0 8px rgba(var(--app__accent), 0.2);
	}
	.theme-toggle__btn svg {
		width: 1rem;
		height: 1rem;
	}

	/* ===========================
	   BEM: input
	   =========================== */
	.input {
		background: var(--app__bg-input);
		border: 1px solid var(--app__border);
		color: var(--app__text-primary);
		border-radius: var(--app__radius-md);
		padding: 0.875rem 1rem;
		font-size: 0.95rem;
		transition: all var(--app__transition);
		outline: none;
		width: 100%;
		font-family: var(--app__font);
		box-sizing: border-box;
	}
	.input:focus {
		border-color: var(--app__border-focus);
		box-shadow: 0 0 0 3px rgba(var(--app__accent), 0.15), 0 0 20px rgba(var(--app__accent), 0.08);
	}
	.input::placeholder {
		color: var(--app__input-placeholder);
	}

	/* ===========================
	   BEM: alert
	   =========================== */
	.alert {
		display: flex;
		align-items: flex-start;
		gap: 0.75rem;
		padding: 1rem;
		border-radius: var(--app__radius-md);
	}
	.alert--error {
		background: rgba(239, 68, 68, 0.08);
		border: 1px solid rgba(239, 68, 68, 0.2);
	}
	.alert--warning {
		background: rgba(245, 158, 11, 0.08);
		border: 1px solid rgba(245, 158, 11, 0.2);
	}
	.alert__icon {
		flex-shrink: 0;
		width: 1.25rem;
		height: 1.25rem;
		margin-top: 0.125rem;
	}
	.alert__icon--error { color: #f87171; }
	.alert__icon--warning { color: #fbbf24; }
	.alert__title {
		font-size: 0.875rem;
		font-weight: 500;
		margin: 0;
	}
	.alert__title--error { color: #fca5a5; }
	.alert__title--warning { color: #fcd34d; }
	html.light .alert__title--error { color: #dc2626; }
	html.light .alert__title--warning { color: #d97706; }
	.alert__desc {
		font-size: 0.75rem;
		margin: 0.25rem 0 0 0;
		opacity: 0.7;
	}
</style>
